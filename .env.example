POSTGRES_USER=wardrobe
POSTGRES_PASSWORD=wardrobe_password
POSTGRES_DB=wardrobe_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXPOSE_PORT=10540

BACKEND_PORT=10510
SERVICE_PORT=10520
FRONTEND_PORT=10530
DB_ADMIN_PORT=10550

FRONTEND_SERVICE_API_URL=http://localhost:10520
CORS_ALLOWED_ORIGINS=http://localhost:10530,http://127.0.0.1:10530

PARSER_SOURCES_FILE=service/config/sources.json
PARSER_DEFAULT_TIMEOUT_SEC=12
PARSER_DEFAULT_MAX_PRODUCTS=5000
PARSER_DEFAULT_SAMPLE_PRODUCTS=5
PARSER_DEFAULT_PARALLEL_WORKERS=12
PARSER_DEFAULT_MAX_RETRIES=2
PARSER_DEFAULT_RETRY_BACKOFF_SEC=0.4
PARSER_DEFAULT_SECOND_PASS_ENABLED=true
PARSER_DEFAULT_SECOND_PASS_TIMEOUT_SEC=20
PARSER_SYNC_MAX_SOURCES=5
