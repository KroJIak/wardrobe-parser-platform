POSTGRES_USER=wardrobe
POSTGRES_PASSWORD=wardrobe_password
POSTGRES_DB=wardrobe_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXPOSE_PORT=10540

BACKEND_PORT=10510
SERVICE_PORT=10520
FRONTEND_PORT=10530
DB_ADMIN_PORT=10550

CORS_ALLOWED_ORIGINS=http://localhost:10530
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
APP_TITLE=Wardrobe Parser Backend API
HEALTH_STATUS_VALUE=ok

PARSER_SOURCES_FILE=service/config/sources.json
PARSER_DEFAULT_TIMEOUT_SEC=8
PARSER_DEFAULT_MAX_PRODUCTS=5000
PARSER_DEFAULT_SAMPLE_PRODUCTS=5
PARSER_DEFAULT_PARALLEL_WORKERS=8
PARSER_DEFAULT_MAX_RETRIES=1
PARSER_DEFAULT_RETRY_BACKOFF_SEC=0.4
PARSER_DEFAULT_SECOND_PASS_ENABLED=true
PARSER_DEFAULT_SECOND_PASS_TIMEOUT_SEC=20
PARSER_SECOND_PASS_MAX_WORKERS=6
PARSER_SECOND_PASS_MIN_BACKOFF_SEC=0.5
PARSER_DISCOVERY_SITEMAP_WORKERS=4
PARSER_DISCOVERY_FAIL_FAST_ON_RATE_LIMIT=false
PARSER_RECOVER_FROM_EXISTING_URLS_ENABLED=true
PARSER_RECOVERY_NETWORK_ENABLED=false
PARSER_RECOVERY_PARALLEL_WORKERS=96
PARSER_RECOVERY_TIMEOUT_SEC=6
PARSER_RECOVERY_MAX_RETRIES=0
PARSER_RECOVERY_RETRY_BACKOFF_SEC=0.2
PARSER_RECOVERY_SECOND_PASS_TIMEOUT_SEC=8
PARSER_EMPTY_DISCOVERY_SOURCE_RETRIES=0
PARSER_EMPTY_DISCOVERY_RETRY_BACKOFF_SEC=0.5
PARSER_RATE_LIMIT_MIN_COOLDOWN_SEC=1.0
PARSER_RATE_LIMIT_JITTER_SEC=0.15
PARSER_TIMEOUT_COOLDOWN_SEC=0.25
PARSER_SOURCE_TIMEOUT_SEC=180
PARSER_CIRCUIT_BREAKER_429_THRESHOLD=5
PARSER_CIRCUIT_BREAKER_MAX_PENALTY=3
PARSER_CIRCUIT_BREAKER_RECOVERY_SUCCESSES=30
PARSER_CIRCUIT_BREAKER_PAUSE_SEC=3.0
PARSER_SYNC_MAX_SOURCES=0
PARSER_SYNC_SOURCE_WORKERS=5
PARSER_SYNC_PERIOD_MINUTES=300
PARSER_JOB_STALE_MINUTES=180

IMAGE_PROXY_TIMEOUT_SEC=10
IMAGE_PROXY_MAX_BYTES=8000000
IMAGE_CACHE_MAX_AGE_SEC=86400
IMAGE_RATE_LIMIT_PER_MINUTE=3000
